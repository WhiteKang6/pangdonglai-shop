<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.database.homework.pangdonglaishop.mapper.UserMapper">
    <update id="updateById">
        update [user]
        <set>
            <if test="name!=null"> name=#{name},</if>
            <if test="age!=null"> age=#{age},</if>
            <if test="sex!=null"> sex=#{sex},</if>
            <if test="status!=null"> status=#{status},</if>
        </set>
        where id=#{id}
    </update>
    <select id="selectPage" resultType="com.database.homework.pangdonglaishop.VO.UserVO">
        select u.*
        from [user] u
        <where>
            <if test="keyword!=null and keyword!=''">
                (u.name like concat('%',#{keyword},'%') or u.username like concat('%',#{keyword},'%'))
            </if>
            <if test="status!=null">
                and u.status=#{status}
            </if>
            <if test="age!=null">
                and u.age=#{age}
            </if>
            <if test="sex!=null">
                and u.sex=#{sex}
            </if>
        </where>

    </select>
</mapper>

